<!DOCTYPE html>
<html lang="pt-br">

<%- include('../partials/head.ejs') %>

<body>

  <%- include('../partials/header.ejs') %>
  <%- include('../partials/sidebar.ejs') %>

  <main id="main" class="main" style="min-height: 85vh; background-color: #f6f9ff;">

    <div class="pagetitle mb-3 px-2">
      <h1 class="fw-bold text-dark text-center text-md-start" style="font-size: 1.5rem;">Relatórios DRE</h1>
    </div>

    <section class="section">
      <div class="row mb-3 mx-0">
        <div class="col-12 px-0">
          <div class="card border-0 shadow-sm" style="border-radius: 15px;">
            <div class="card-body p-2 p-md-3">
              <div class="row g-2 align-items-center">
                
                <div class="col-12 col-md-4 d-flex align-items-center mb-2 mb-md-0">
                  <div class="rounded-3 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-2" 
                       style="width: 40px; height: 40px; flex-shrink: 0;">
                    <i class="bi bi-calendar-check text-primary fs-5"></i>
                  </div>
                  <div>
                    <p class="text-muted fw-bold mb-0 text-uppercase" style="font-size: 0.6rem; letter-spacing: 0.5px;">Análise Atual</p>
                    <h6 class="fw-bold mb-0 text-dark" style="font-size: 0.9rem;">
                      <%= date1.split('-').reverse().join('/') %> até
                      <%= date2.split('-').reverse().join('/') %>
                    </h6>
                  </div>
                </div>

                <div class="col-12 col-md-8">
                  <form id="FormModal" action="/dashboard/dre" method="post">
                  <div class="row g-1 align-items-center">
                    <div class="col col-sm">
                      <input type="date" class="form-control form-control-sm border-0 bg-light shadow-none" 
                     name="date1" value="<%= date1 %>"
                             style="border-radius: 8px; height: 38px; font-size: 0.85rem;">
                    </div>
                    <div class="col-auto d-none d-sm-block px-1">
                      <i class="bi bi-arrow-right text-muted small"></i>
                    </div>
                    <div class="col col-sm">
                      <input type="date" class="form-control form-control-sm border-0 bg-light shadow-none"
                        name="date2" value="<%= date2 %>"
                             style="border-radius: 8px; height: 38px; font-size: 0.85rem;">
                    </div>
                    <div class="col-12 col-sm-auto mt-2 mt-sm-0">
                      <button type="submit" class="btn btn-primary btn-sm w-100 px-3 d-flex align-items-center justify-content-center gap-2 shadow-sm" 
                              style="border-radius: 8px; height: 38px; font-weight: 600;">
                        <i class="bi bi-search" style="font-size: 0.8rem;"></i>
                        <span style="font-size: 0.85rem;">Carregar</span>
                      </button>
                    </div>
                  </div>
                  </form>
                </div>

              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row mx-0">
        <div class="col-lg-9 mb-3 px-0 pe-lg-3">
          <div class="card border-0 shadow-sm" style="border-radius: 20px; overflow: hidden;">
            
            <div class="card-header border-0 p-3 p-md-4 d-flex flex-wrap justify-content-between align-items-center" style="background-color: #0b0f19;">
              <div class="text-start text-md-start">
                <h5 class="text-white fw-bold mb-0">Relatório Mensal</h5>
                <span class="text-muted text-uppercase" style="font-size: 9px; letter-spacing: 1px;">Caixa</span>
              </div>
              <div class="text-end">
                <span class="text-muted d-block" style="font-size: 0.7rem;">Lucro Líquido</span>
                <h2 class="fw-bold mb-0" style="color: #10b981; font-size: 1.6rem;">
                  <%= new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(liquido) %>
                </h2>
              </div>
            </div>

            <div class="card-body p-3 p-md-4 bg-white">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-success fw-bold text-uppercase" style="font-size: 0.75rem;"><i class="bi bi-plus-circle me-1"></i> Receitas</span>
                <span class="text-success fw-bold" style="font-size: 0.9rem;">
                  <%= new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(totalReceita) %>
                </span>
              </div>
              <div class="mb-4">
                 <% categoryReceita.forEach(function(dados){ %>
                <div class="d-flex justify-content-between py-1 border-bottom-0">
                  <span class="text-secondary small"><%= dados.name %></span>
                  <span class="fw-bold text-dark small">
                  <%= new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(dados.amount) %>
                </span>
                </div>
                <% }); %>
              </div>

              <hr class="my-3 opacity-5">

              <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-danger fw-bold text-uppercase" style="font-size: 0.75rem;"><i class="bi bi-dash-circle me-1"></i> Despesas</span>
                <span class="text-danger fw-bold" style="font-size: 0.9rem;">
                  (<%= new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(totalDespesa) %>)
                </span>
              </div>
              <div>
                 <% categoryDespesa.forEach(function(dados){ %>
                <div class="d-flex justify-content-between py-1">
                  <span class="text-secondary small"><%= dados.name %></span>
                  <span class="fw-bold text-dark small">
                    <%= new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(dados.amount) %>
                  </span>
                </div>
                 <% }); %>
              </div>

              <div class="mt-4 pt-3 border-top text-center">
                <p class="text-muted mb-0 small text-uppercase">Resultado Final</p>
                <h3 class="fw-bold mb-0" style="color: #10b981;">
                  (<%= new Intl.NumberFormat('pt-BR', {
                    style: 'currency',
                    currency: 'BRL'
                  }).format(liquido) %>)
                </h3>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-3 px-0">
          <div class="card border-0 shadow-sm mb-3" style="border-radius: 15px;">
            <div class="card-body p-3 text-center">
              <p class="text-muted fw-bold text-uppercase mb-1" style="font-size: 0.65rem;">Eficiência</p>

              <% 
                const efficiencyValue =
                  Efficiency != null && isFinite(Efficiency)
                    ? Number(Efficiency).toFixed(2)
                    : '0.00';
              %>

              <h4 class="fw-bold text-success mb-2">
                <%= efficiencyValue %>%
              </h4>

              <div class="progress mb-2" style="height: 6px;">
                <div class="progress-bar bg-success"
                    style="width: <%= efficiencyValue %>%">
                </div>
              </div>
            </div>
          </div>


          <div class="card border-0 shadow-sm text-white" style="border-radius: 15px; background: #5a57e6;">
            <div class="card-body p-3">
              <h6 class="fw-bold d-flex align-items-center gap-2" style="font-size: 0.85rem;">
                <i class="bi bi-lightbulb text-warning"></i> Dica do Mês
              </h6>
              <p class="mb-0 opacity-75" style="font-size: 0.75rem;">Os gastos fixos com moradia representam uma parcela significativa do orçamento e reduzem sua flexibilidade financeira.</p>
              <br/>
              <p class="mb-0 opacity-75" style="font-size: 0.75rem;">Despesas com combustível e manutenção indicam um impacto relevante no orçamento mensal.</p>
               <br/>
              <p class="mb-0 opacity-75" style="font-size: 0.75rem;">A alimentação consome uma fatia considerável da renda e merece acompanhamento mensal.</p>
               <br/>
               <p class="mb-0 opacity-75" style="font-size: 0.75rem;">O saldo mensal positivo indica boa gestão, mas pode ser melhor direcionado para reserva de emergência.</p>
               <br/>
               <p class="mb-0 opacity-75" style="font-size: 0.75rem;">O acompanhamento mensal do DRE ajuda a identificar desvios e oportunidades de economia.</p>
              
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer.ejs') %>
  <%- include('../partials/script.ejs') %>

</body>
</html>