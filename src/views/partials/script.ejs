  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
const form = document.getElementById('FormModal');

form.addEventListener('submit', function (e) {
  // 1. Evita o envio imediato apenas para abrir o alerta
  e.preventDefault();

  let progress = 0;
  let timerInterval;

  Swal.fire({
    title: '🔒 Processando com segurança',
    html: `
      <div style="font-size:13px; color:#6b7280; line-height:1.6; margin-bottom:14px;">
         ⚙️ Aplicando suas alterações e validando os dados
          com total segurança.
      </div>
      <div style="font-weight:600; font-size:14px; color:#111827;">
       ⏳ <span id="progressValue">0%</span>
      </div>
    `,
    showConfirmButton: false,
    allowOutsideClick: false,
    allowEscapeKey: false,
    backdrop: 'rgba(15, 23, 42, 0.55)',
    customClass: { container: 'swal-blur-backdrop' },
    didOpen: () => {
      Swal.showLoading();
      const progressText = document.getElementById('progressValue');
      
      // Animação visual infinita até a página mudar
      timerInterval = setInterval(() => {
        if (progress < 99) { // Vai até 99% e para até a página recarregar
          progress++;
          if (progressText) progressText.textContent = `${progress}%`;
        }
      }, 100);

      // 2. ENVIA O FORMULÁRIO DE VERDADE
      // Usamos form.submit() direto no elemento DOM para ignorar este listener de 'submit'
      form.submit();
    }
  });
});
</script>


<script src="/assets/js/main.js"></script>

  <script>
  const Toast = Swal.mixin({
    toast: true,
    position: 'top-end',
    showConfirmButton: false,
    timer: 5000,
    timerProgressBar: true
  });

  <% if (typeof messages !== 'undefined' && messages.info) { %>
    Toast.fire({
      icon: 'success',
      title: '<%= messages.info %>'
    });
  <% } %>

  <% if (typeof messages !== 'undefined' && messages.error) { %>
    Toast.fire({
      icon: 'error',
      title: '<%= messages.error %>'
    });
  <% } %>
</script>

