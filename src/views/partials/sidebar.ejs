<script>
  document.addEventListener('DOMContentLoaded', () => {
  // Seleciona TODOS os elementos que possuem a classe .menuLoad
  const menuLinks = document.querySelectorAll('.menuLoad');

  menuLinks.forEach(link => {
    link.addEventListener('click', function (e) {
      e.preventDefault();
      
      // Armazena o link de destino para usar depois
      const destination = this.href;

      let progress = 0;
      let interval;

      Swal.fire({
        title: '⏳ Carregando, aguarde...',
         html: `
          <div style="
            font-size:13px;
            color:#6b7280;
            line-height:1.6;
            margin-bottom:14px;
          ">
             ✅ Validando informações e preparando o ambiente...
          </div>

          <div style="
            font-weight:600;
            font-size:14px;
            color:#111827;
            letter-spacing:0.4px;
          ">
           ⏳ <span id="progressValue">0%</span>
          </div>
        `,
        
        showConfirmButton: false,
        allowOutsideClick: false,
        allowEscapeKey: false,
        backdrop: 'rgba(15, 23, 42, 0.55)',
        customClass: {
          container: 'swal-blur-backdrop'
        },
        didOpen: () => {
          Swal.showLoading();
          const progressText = document.getElementById('progressValue');

          interval = setInterval(() => {
            if (progress < 95) {
              progress++;
              progressText.textContent = `${progress}%`;
            }
          }, 120);
        }
      });    

      // Aguarda um curto período para o Swal renderizar e então navega
      setTimeout(() => {
        window.location.href = destination;
      }, 700);
    });
  });
});
</script>



<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuIA = document.getElementById('menuConsultorIA');
    if (!menuIA) return;

    menuIA.addEventListener('click', function (e) {
      // evita navegação imediata
      e.preventDefault();

      let progress = 0;
      let interval;

      Swal.fire({
        title: '🤖 Consultor Inteligente',
        html: `
          <div style="
            font-size:13px;
            color:#6b7280;
            line-height:1.6;
            margin-bottom:14px;
          ">
             📊 Estamos analisando seus dados financeiros e
             gerando insights personalizados com IA.
          </div>

          <div style="
