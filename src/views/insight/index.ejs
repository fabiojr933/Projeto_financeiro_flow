<!DOCTYPE html>
<html lang="pt-br">

<%- include('../partials/head.ejs') %>

<body>

<%- include('../partials/header.ejs') %>
<%- include('../partials/sidebar.ejs') %>

<%
  // ============================
  // PROTEÇÃO TOTAL CONTRA ERROS
  // ============================
  const safeDados =
    typeof dados !== 'undefined' && dados
      ? dados
      : {
          health_score: 0,
          dicas: ['ℹ️ Você está utilizando a versão gratuita da nossa Inteligência Artificial. Em alguns momentos, o sistema pode não gerar dicas ou não apresentar insights completos.'],
          error: null,
          message: null
        };

  const score = Number(safeDados.health_score) || 0;
  const circumference = 283;
  const progress = (score / 100) * circumference;
%>

<main id="main" class="main" style="min-height: 85vh; background-color: #f6f9ff;">

<!-- TÍTULO + FILTRO -->
<div class="row align-items-center mb-4">
  <!-- TÍTULO -->
  <div class="col-md-6">
    <h1 style="font-size: 1.3rem; font-weight: 700; color: #1a1a3d;">
      IA Insights
    </h1>
  </div>

  <!-- FORM DO FILTRO -->
  <div class="col-md-6">
    <form id="formConsultor" action="/dashboard/consultor" method="post"
          class="d-flex justify-content-md-end gap-2">

      <div class="filter-box shadow-sm d-flex align-items-center gap-2 px-2">
        <span class="filter-label">Período</span>
        <input type="date" name="date1" value="<%= date1 %>" class="filter-date" />
        <i class="bi bi-chevron-right text-muted small"></i>
        <input type="date" name="date2" value="<%= date2 %>" class="filter-date" />
      </div>

      <button type="submit" class="filter-box shadow-sm filter-btn">
        <i class="bi bi-funnel"></i>
      </button>

    </form>
  </div>

</div>

<!-- CONTEÚDO NORMAL DA PÁGINA -->
<section class="section">

  <div class="row mb-4">
    <div class="col-12">
      <div class="card border-0 shadow-lg text-white"
           style="background-color: #0b0e1f; border-radius: 35px; overflow: hidden;">

        <div class="card-body p-4 p-md-5 d-flex flex-column flex-md-row justify-content-between align-items-center">

          <div class="d-flex align-items-center">
            <div class="bg-dark p-3 rounded-4 me-3 border border-secondary border-opacity-25"
                 style="background-color: #1a1d2e !important;">
              <i class="bi bi-cpu text-white fs-1"></i>
            </div>

            <div>
              <h2 class="fw-bold mb-0">Consultor Inteligente</h2>
              <span class="text-uppercase small fw-bold"
                    style="color: #6366f1; letter-spacing: 1.5px; font-size: 0.75rem;">
                Powered by DeepSeek AI
              </span>
              <p class="mt-2 mb-0 opacity-75">
                Análise rigorosa dos seus padrões financeiros.
              </p>
            </div>
          </div>

        <button
          type="button"
          id="btnOptimize"
          class="btn btn-primary px-4 py-2 fw-bold"
          style="background:#5a57e6;border:none;border-radius:12px;font-size:1rem;">
          <i class="bi bi-stars me-2"></i>
          Consultar
        </button>


        </div>
      </div>
    </div>
  </div>

</section>


    <!-- CONTEÚDO -->
    <div class="row">

      <!-- HEALTH SCORE -->
      <div class="col-lg-6 mb-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 30px;">
          <div class="card-body p-5 text-center d-flex flex-column align-items-center justify-content-center">

            <span class="text-uppercase fw-bold text-muted small mb-4" style="letter-spacing: 2px;">
              <i class="bi bi-shield-check me-1"></i>
              Health Score
            </span>

            <div class="position-relative d-flex align-items-center justify-content-center mb-4"
                 style="width: 250px; height: 250px;">

              <svg viewBox="0 0 100 100"
                   style="transform: rotate(-90deg); width: 100%; height: 100%;">
                <circle cx="50" cy="50" r="45"
                        fill="none"
                        stroke="#f0f2f5"
                        stroke-width="8"></circle>

                <circle cx="50" cy="50" r="45"
                        fill="none"
                        stroke="#5a57e6"
                        stroke-width="8"
                        stroke-linecap="round"
                        stroke-dasharray="<%= progress %> <%= circumference %>">
                </circle>
              </svg>

              <div class="position-absolute text-center">
                <span class="d-block fw-bold text-dark"
                      style="font-size: 5rem; line-height: 1;">
                  <%= score %>
                </span>
                <span class="text-muted fw-bold small">PONTOS</span>
              </div>
            </div>

            <% if (safeDados.error) { %>
              <p class="text-warning fw-bold small">
                Score indisponível no momento
              </p>
            <% } else { %>
              <p class="text-muted mt-3">
                Gere insights para ver seu score.
              </p>
            <% } %>

          </div>
        </div>
      </div>

      <!-- DICAS -->
      <div class="col-lg-6 mb-4">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 30px;">
          <div class="card-body p-4 p-md-5">

            <h5 class="fw-bold text-dark mb-4">Dicas Recomendadas</h5>

            <% if (safeDados.error === 'quota') { %>

              <div class="alert alert-warning d-flex align-items-center gap-3">
                <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                <div>
                  <strong>Limite da IA atingido</strong><br>
                  <span class="small opacity-75">
                    Você excedeu o número de análises disponíveis hoje.<br>
                    Tente novamente mais tarde.
                  </span>
                </div>
              </div>

            <% } else if (safeDados.error) { %>

              <div class="alert alert-danger d-flex align-items-center gap-3">
                <i class="bi bi-x-circle-fill fs-4"></i>
                <div>
                  <strong>Erro ao gerar insights</strong><br>
                  <span class="small opacity-75">
                    Ocorreu um erro inesperado. Tente novamente.
                  </span>
                </div>
              </div>

            <% } else if (safeDados.dicas && safeDados.dicas.length > 0) { %>

              <ul class="list-group list-group-flush">
                <% safeDados.dicas.forEach((dica) => { %>
                  <li class="list-group-item border-0 px-0 d-flex align-items-start">
                    <i class="bi bi-lightbulb-fill text-warning me-3 fs-5"></i>
                    <span><%= dica %></span>
                  </li>
                <% }) %>
              </ul>

            <% } else { %>

              <div class="d-flex flex-column align-items-center justify-content-center h-75 opacity-50">
                <i class="bi bi-lightbulb fs-1 mb-2 text-primary"></i>
                <p class="small text-center">
                  Clique em <strong>Otimizar Finanças</strong><br>
                  para gerar insights inteligentes.
                </p>
              </div>

            <% } %>

          </div>
        </div>
      </div>

    </div>
  </section>
</main>

<%- include('../partials/footer.ejs') %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('btnOptimize');
  const form = document.getElementById('formConsultor');

  if (!btn || !form) return;

  btn.addEventListener('click', () => {
    let progress = 0;
    let interval;

    Swal.fire({
      title: '🤖 Consultor Inteligente',
      html: `
        <div style="font-size:13px;color:#6b7280;margin-bottom:14px">
          📊 Estamos analisando seus dados financeiros e
          gerando insights personalizados com IA.
        </div>
        <div style="font-weight:600;font-size:14px">
          ⏳ <span id="progressValue">0%</span>
        </div>
      `,
      showConfirmButton: false,
      allowOutsideClick: false,
      allowEscapeKey: false,
      backdrop: 'rgba(15, 23, 42, 0.55)',
      didOpen: () => {
        Swal.showLoading();
        const progressText = document.getElementById('progressValue');

        interval = setInterval(() => {
          if (progress < 95) {
            progress++;
            progressText.textContent = `${progress}%`;
          }
        }, 120);
      }
    });

    setTimeout(() => {
      clearInterval(interval);
      form.submit(); // ✅ ENVIA date1 e date2
    }, 600);
  });
});
</script>


</body>
</html>
